{
  "themes": {
    "pixel-cozy": {
      "name": "Pixel Cozy",
      "description": "Warm, retro pixel-art aesthetic inspired by classic 8-bit games. Soft colors, rounded sprites.",
      "palette": {
        "background": "#1a1a2e",
        "primary": "#16c784",
        "secondary": "#ffd700",
        "accent": "#ff6b6b",
        "text": "#f0f0f0",
        "quarantine": "#cc5555"
      },
      "sprites": {
        "claim": {
          "color": "#4a9eff",
          "emoji": "🔵",
          "size": "32x32"
        },
        "evidence": {
          "color": "#ffd700",
          "emoji": "🟡",
          "size": "32x32"
        },
        "artifact": {
          "color": "#b19cd9",
          "emoji": "🟣",
          "size": "32x32"
        },
        "receipt": {
          "color": "#16c784",
          "emoji": "🟢",
          "size": "32x32"
        },
        "wild_text": {
          "color": "#ff6b6b",
          "emoji": "🔴",
          "size": "32x32",
          "quarantined": true
        }
      },
      "zones": {
        "exploration": {
          "label": "🌍 EXPLORATION",
          "background_color": "#2a3f5f",
          "border_color": "#4a9eff"
