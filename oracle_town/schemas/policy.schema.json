{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oracle-town.local/schemas/policy.schema.json",
  "title": "Policy",
  "description": "Governance policy with versioning, quorum rules, revocation, and invariants.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id",
    "policy_version",
    "policy_hash",
    "effective_date",
    "quorum_rules",
    "revoked_keys",
    "revoked_attestors"
  ],
  "properties": {
    "policy_id": {
      "type": "string",
      "pattern": "^POL-[A-Z0-9_-]{3,32}$",
      "description": "Unique policy identifier (e.g., POL-ORACLE-TOWN)."
    },
    "policy_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "description": "Semantic version (MAJOR.MINOR.PATCH)."
    },
    "policy_hash": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$",
      "description": "SHA256 hash of canonical policy JSON (for determinism verification)."
    },
    "effective_date": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this policy becomes active."
    },
    "parent_policy_hash": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$",
      "description": "Optional parent policy hash (for lineage tracking)."
    },
    "change_rationale": {
      "type": "string",
      "minLength": 10,
      "description": "Human-readable reason for policy change (required for audits)."
    },
    "quorum_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_min_quorum", "obligation_specific_rules"],
      "properties": {
        "default_min_quorum": {
          "type": "integer",
          "minimum": 1,
          "description": "Default minimum number of distinct attestor classes required."
        },
        "obligation_specific_rules": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["required_attestor_classes", "min_quorum"],
            "properties": {
              "required_attestor_classes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["CI_RUNNER", "SECURITY", "LEGAL", "DOMAIN_OWNER", "RELEASE_MANAGER", "MOCK_FACTORY"]
                },
                "minItems": 1,
                "uniqueItems": true
              },
              "min_quorum": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "description": "Per-obligation quorum rules (key = obligation_name)."
        }
      }
    },
    "revoked_keys": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key_id", "revoked_at", "reason"],
        "properties": {
          "key_id": {
            "type": "string",
            "minLength": 3,
            "description": "Public key identifier that has been revoked."
          },
          "revoked_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of revocation."
          },
          "reason": {
            "type": "string",
            "minLength": 5,
            "description": "Reason for revocation (e.g., 'Key compromise', 'Attestor role change')."
          }
        }
      },
      "description": "Append-only list of revoked signing keys."
    },
    "revoked_attestors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["attestor_id", "revoked_at", "reason"],
        "properties": {
          "attestor_id": {
            "type": "string",
            "minLength": 3,
            "description": "Attestor identifier that has been revoked."
          },
          "revoked_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of revocation."
          },
          "reason": {
            "type": "string",
            "minLength": 5,
            "description": "Reason for revocation."
          }
        }
      },
      "description": "Append-only list of revoked attestors."
    },
    "key_registry_hash": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$",
      "description": "SHA256 hash of pinned key registry (oracle_town/keys/public_keys.json)"
    },
    "budget_caps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_proposals_per_run": {
          "type": "integer",
          "minimum": 1,
          "default": 100
        },
        "max_obligations_per_run": {
          "type": "integer",
          "minimum": 1,
          "default": 50
        },
        "max_free_text_bytes": {
          "type": "integer",
          "minimum": 1024,
          "default": 102400
        },
        "max_metadata_fields": {
          "type": "integer",
          "minimum": 1,
          "default": 20
        }
      },
      "description": "Budget caps for Creative Town outputs (anti-DOS)."
    },
    "invariants": {
      "type": "object",
      "additionalProperties": { "type": "boolean" },
      "description": "Kernel invariants that must always be true (e.g., fail_closed, no_self_attestation)."
    },
    "sampling_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 0.05,
      "description": "Random audit sampling rate (0.05 = 5% of SHIP runs audited)."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean", "null"] },
      "description": "Optional non-sovereign metadata for audit trail."
    }
  }
}
