{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oracle-town.local/schemas/ui_event_stream.schema.json",
  "title": "UIEventStream",
  "description": "Deterministic, append-only UI replay log for marketing/demo. No authority. References artifacts by id+hash only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stream_id",
    "run_id",
    "created_at",
    "ui_mode",
    "events",
    "hashes",
    "constraints"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0.0"] },
    "stream_id": { "type": "string", "pattern": "^UIS-[A-Z0-9]{8,40}$" },
    "run_id": { "type": "string", "minLength": 4, "maxLength": 128 },
    "created_at": { "type": "string", "format": "date-time" },

    "ui_mode": {
      "type": "string",
      "enum": ["control_room", "town_view", "hybrid"]
    },

    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["seq", "t_ms", "event_type", "actor", "payload"],
        "properties": {
          "seq": { "type": "integer", "minimum": 1 },
          "t_ms": { "type": "integer", "minimum": 0, "maximum": 600000 },
          "event_type": {
            "type": "string",
            "enum": [
              "CLAIM_RECEIVED",
              "DISTRICT_STARTED",
              "NODE_STEP",
              "MESSAGE_ROUTED",
              "PROPOSAL_EMITTED",
              "PACKET_EMITTED",
              "CONCIERGE_TRANSLATED",
              "FACTORY_TEST_STARTED",
              "FACTORY_TEST_RESULT",
              "ATTESTATION_WRITTEN",
              "MAYOR_DECISION_REFERENCED",
              "UI_ANNOTATION"
            ]
          },

          "actor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "id"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["system", "district", "agent", "concierge", "factory", "mayor", "observer_ui"]
              },
              "id": { "type": "string", "minLength": 1, "maxLength": 128 }
            }
          },

          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["summary"],
            "properties": {
              "summary": { "type": "string", "minLength": 1, "maxLength": 2000 },

              "refs": {
                "description": "References to artifacts by id+hash only.",
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["ref_kind", "ref_id", "sha256"],
                  "properties": {
                    "ref_kind": {
                      "type": "string",
                      "enum": [
                        "claim",
                        "proposal_envelope",
                        "builder_packet",
                        "briefcase",
                        "test_run",
                        "attestation",
                        "decision_record"
                      ]
                    },
                    "ref_id": { "type": "string", "minLength": 1, "maxLength": 256 },
                    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
                  }
                }
              },

              "ui_hints": {
                "description": "Purely presentational hints for animation, never interpreted as logic.",
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "focus_node": { "type": "string", "maxLength": 64 },
                  "sound": { "type": "string", "enum": ["none", "tick", "warning", "success_fanfare"] },
                  "badge": { "type": "string", "maxLength": 64 },
                  "color_tag": { "type": "string", "maxLength": 32 }
                }
              },

              "metrics": {
                "description": "Optional metrics for UI display; not used for governance decisions.",
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "steps": { "type": "integer", "minimum": 0, "maximum": 200000 },
                  "proposal_count": { "type": "integer", "minimum": 0, "maximum": 200000 },
                  "packet_count": { "type": "integer", "minimum": 0, "maximum": 200000 },
                  "tests_passed": { "type": "integer", "minimum": 0, "maximum": 200000 },
                  "tests_failed": { "type": "integer", "minimum": 0, "maximum": 200000 }
                }
              }
            }
          }
        }
      }
    },

    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonical_sha256"],
      "properties": {
        "canonical_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },

    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["non_sovereign", "no_attestation_forgery"],
      "properties": {
        "non_sovereign": { "type": "boolean", "const": true },
        "no_attestation_forgery": {
          "description": "UI stream must not contain attestation bodies; only references.",
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
