{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oracle-town.local/schemas/memory_fact.schema.json",
  "title": "MemoryFact",
  "description": "Atomic, timestamped governance insight. Never deleted, only superseded. Forms the knowledge graph.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "fact",
    "timestamp",
    "status",
    "source",
    "entity_type",
    "entity_slug"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]{8,64}$",
      "description": "Unique fact identifier (deterministic hash of entity+fact+timestamp)"
    },
    "fact": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "The atomic insight (e.g. 'Quorum-by-class succeeded with K3 invariant', 'Fast-track failed 3x in succession')"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when fact was recorded"
    },
    "status": {
      "type": "string",
      "enum": ["active", "superseded", "historical"],
      "description": "active: current truth. superseded: contradicted by newer fact. historical: old but contextual."
    },
    "source": {
      "type": "string",
      "enum": ["cycle_output", "pattern_detection", "emergence_signal", "synthesis_inference"],
      "description": "Where the fact originated"
    },
    "entity_type": {
      "type": "string",
      "enum": ["decision", "proposal_archetype", "invariant_event", "lane_performance", "emergence_signal"],
      "description": "Type of entity this fact describes"
    },
    "entity_slug": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$",
      "description": "Slug of the entity (e.g. 'quorum_by_class', 'fast_track_lane', 'k0_violation')"
    },
    "category": {
      "type": "string",
      "enum": [
        "constraint_violation",
        "pattern_success",
        "pattern_failure",
        "lane_effectiveness",
        "convergence",
        "divergence",
        "emergence",
        "constitutional_drift",
        "performance_metric",
        "best_practice"
      ],
      "description": "Classification of the insight"
    },
    "evidence": {
      "type": "object",
      "description": "Supporting data (cycles involved, metrics, etc.)",
      "additionalProperties": true
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of fact IDs that this fact contradicts or replaces"
    },
    "supersededBy": {
      "type": "string",
      "description": "ID of the fact that made this one obsolete"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence level (0=uncertain, 1=deterministic/proven). Only informational, not actionable."
    }
  }
}
