{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oracle_town/federation/schemas/federation_link_v1.schema.json",
  "title": "FEDERATION_LINK_V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "link_id",
    "treaty_id",
    "from_town",
    "to_town",
    "from_cum_hash",
    "to_cum_hash",
    "timestamp"
  ],
  "properties": {
    "schema_version": { "const": "FED_LINK_V1" },
    "link_id": { "type": "string", "minLength": 8, "maxLength": 128 },
    "treaty_id": { "type": "string", "minLength": 8, "maxLength": 128 },
    "from_town": { "type": "string", "minLength": 2, "maxLength": 64 },
    "to_town": { "type": "string", "minLength": 2, "maxLength": 64 },
    "from_cum_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "to_cum_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "timestamp": { "type": "string", "description": "ISO-8601 UTC" },
    "evidence": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "notes": { "type": ["string", "null"] }
  }
}
