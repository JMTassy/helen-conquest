{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oracle_town/federation/schemas/federation_treaty_v1.schema.json",
  "title": "FEDERATION_TREATY_V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "treaty_id",
    "created_at",
    "towns",
    "policies"
  ],
  "properties": {
    "schema_version": { "const": "FED_TREATY_V1" },
    "treaty_id": { "type": "string", "minLength": 8, "maxLength": 128 },
    "created_at": { "type": "string", "description": "ISO-8601 UTC" },
    "towns": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["town_id", "public_key_hash"],
        "properties": {
          "town_id": { "type": "string", "minLength": 2, "maxLength": 64 },
          "public_key_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "endpoint": { "type": ["string", "null"] }
        }
      }
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_required",
        "allowlist_event_types",
        "min_quorum"
      ],
      "properties": {
        "receipt_required": { "type": "boolean" },
        "allowlist_event_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "min_quorum": { "type": "integer", "minimum": 1 }
      }
    },
    "notes": { "type": ["string", "null"] }
  }
}
