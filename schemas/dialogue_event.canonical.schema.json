{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Canonical Dialogue Event (Payload/Meta Split)",
  "description": "NDJSON event for HER/HAL dialogue with deterministic payload and observational meta",
  "type": "object",
  "required": [
    "type",
    "seq",
    "payload",
    "payload_hash",
    "prev_cum_hash",
    "cum_hash"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["turn", "milestone", "seal"],
      "description": "Event type"
    },
    "seq": {
      "type": "integer",
      "minimum": 0,
      "description": "Monotonically increasing sequence number"
    },
    "payload": {
      "type": "object",
      "description": "Hash-bound deterministic data only",
      "required": ["turn", "hal", "channel_contract"],
      "properties": {
        "turn": {
          "type": "integer",
          "minimum": 1,
          "description": "Turn number in dialogue"
        },
        "hal": {
          "$ref": "#/definitions/hal_verdict_v1",
          "description": "MAYOR verdict (HAL_VERDICT_V1)"
        },
        "her_text": {
          "type": ["string", "null"],
          "description": "HELEN text (optional; if included, deterministic)"
        },
        "channel_contract": {
          "type": "string",
          "enum": ["HER_HAL_V1"],
          "description": "Contract version"
        }
      },
      "additionalProperties": false
    },
    "meta": {
      "type": "object",
      "description": "Observational metadata (excluded from hashing)",
      "properties": {
        "timestamp_utc": {
          "type": "string",
          "format": "date-time",
          "description": "Wall-clock time (NOT hash-bound)"
        },
        "raw_text": {
          "type": ["string", "null"],
          "description": "Original [HER]/[HAL] text blob for audit trail"
        },
        "notes": {
          "type": ["string", "null"],
          "description": "Operator notes"
        }
      },
      "additionalProperties": false
    },
    "payload_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA256(Canon(payload))"
    },
    "prev_cum_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Cumulative hash from previous event"
    },
    "cum_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA256(prev_cum_hash || payload_hash)"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "hal_verdict_v1": {
      "type": "object",
      "title": "HAL_VERDICT_V1",
      "description": "Machine-facing governance verdict (MAYOR)",
      "required": [
        "verdict",
        "reasons_codes",
        "required_fixes",
        "certificates",
        "refs"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["PASS", "WARN", "BLOCK"],
          "description": "Outcome"
        },
        "reasons_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z0-9_]{3,64}$",
            "description": "Stable reason code"
          },
          "minItems": 1,
          "description": "MUST be lexicographically sorted"
        },
        "reasons_human": {
          "type": ["array", "null"],
          "items": {
            "type": "string",
            "description": "Prose explanation (not used for gating)"
          },
          "description": "Optional human-readable reasons"
        },
        "required_fixes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z0-9_]{3,64}$",
            "description": "Stable fix code"
          },
          "description": "MUST be lexicographically sorted"
        },
        "certificates": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z0-9_]{3,64}$",
            "description": "Proof code (e.g., KTAU_OK, RHO_OK, FORMAL_I1_OK)"
          },
          "description": "Certificates earned (may be empty)"
        },
        "refs": {
          "type": "object",
          "required": [
            "run_id",
            "kernel_hash",
            "policy_hash",
            "ledger_cum_hash",
            "identity_hash"
          ],
          "properties": {
            "run_id": {
              "type": "string",
              "minLength": 1,
              "description": "Run identifier"
            },
            "kernel_hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$",
              "description": "SHA256 of kernel code"
            },
            "policy_hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$",
              "description": "SHA256 of policy rules"
            },
            "ledger_cum_hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$",
              "description": "Cumulative hash at this turn"
            },
            "identity_hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$",
              "description": "SHA256(ledger_cum_hash || kernel_hash || policy_hash)"
            }
          },
          "additionalProperties": false,
          "description": "Reference hashes for reproducibility"
        },
        "mutations": {
          "type": "array",
          "items": {
            "type": "object",
            "description": "Proposed policy mutations (read-only; never auto-applied)"
          },
          "description": "Policy change proposals (empty unless WARN/BLOCK)"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "mutations": {
                "minItems": 1
              }
            }
          },
          "then": {
            "properties": {
              "verdict": {
                "enum": ["WARN", "BLOCK"]
              }
            }
          }
        }
      ]
    }
  }
}
