# HELEN DEPLOYMENT CONFIGURATION

# Ollama / Model Configuration
OLLAMA_HOST=http://ollama:11434
HELEN_MODEL=gemma:4b
HELEN_TEMPERATURE=0.3
HELEN_MAX_TOKENS=2048

# Session & Persistence
HELEN_SESSION_DIR=/persistent/sessions
HELEN_LEDGER_PATH=/persistent/ledger.ndjson
HELEN_MEMORY_DB=/persistent/helen.db

# API Configuration
HELEN_API_HOST=0.0.0.0
HELEN_API_PORT=8000
HELEN_LOG_LEVEL=INFO

# Avatar Frontend
AIRI_API_URL=http://localhost:8000
AIRI_WS_URL=ws://localhost:8000
AIRI_PORT=5173

# Telegram Integration (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=http://localhost:8001/webhook

# Line Integration (optional)
LINE_CHANNEL_TOKEN=
LINE_CHANNEL_SECRET=
LINE_WEBHOOK_URL=http://localhost:8002/webhook

# Constitution / Governance
CONSTITUTION_PATH=/app/constitution
GOVERNANCE_MODE=strict
RATIFICATION_GATE=zero_violations
