{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "oath",
        "proposal",
        "check",
        "witness",
        "contradiction_scan",
        "revision",
        "verdict",
        "block",
        "amendment"
      ]
    },
    "actor": {
      "type": "string",
      "enum": [
        "user",
        "helen",
        "mayor"
      ]
    },
    "turn": {
      "type": "integer"
    },
    "entry_id": {
      "type": "string"
    },
    "intent": {
      "type": "string"
    },
    "proposal": {
      "type": "string"
    },
    "check": {
      "type": "string"
    },
    "result": {
      "type": "string"
    },
    "observation": {
      "type": "string"
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "linked_to": {
      "type": "string"
    },
    "self_detected": {
      "type": "boolean"
    },
    "contradictions": {
      "type": "array"
    }
  },
  "required": [
    "type",
    "actor",
    "turn",
    "entry_id"
  ]
}