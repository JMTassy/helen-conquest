{
  "project": {
    "title": "HELEN_3MIN_TEST_001",
    "mode": "music_clip_ultra_cheap",
    "duration_sec": 180,
    "fps_out": 24,
    "keyframe_count": 18,
    "renderer_policy": "real+twin",
    "gate_policy": "keyframes_only",
    "motion_policy": "ken_burns_crossfade",
    "telegram_publish": true,
    "render_mode": "REAL_master_TWIN_oracle"
  },
  "identity": {
    "identity_id": "HELEN_CANONICAL_V1",
    "math_object_ref": "helen_math_identity_v1",
    "lock_z_id": true,
    "latent_spec": {
      "id_dim": 256,
      "control_dim": 128,
      "style_dim": 128,
      "temporal_dim": 0
    }
  },
  "gates": {
    "real_profile": "HELEN_REAL_V1",
    "twin_profile": "HELEN_TWIN_V1",
    "mirror_oracle": true,
    "thermostat_mode": "cold_to_warm",
    "retry_policy": {
      "max_retries_per_keyframe": 2,
      "first_action_on_fail": "reduce_control_step",
      "second_action_on_fail": "reduce_style_step",
      "third_action_on_fail": "fallback_to_previous_accepted"
    }
  },
  "style_defaults": {
    "watermark": "HELEN / CONQUEST",
    "subtitle_mode": "scene_labels",
    "palette_mode": "auto_by_emotion",
    "real_weight_default": 0.6,
    "twin_weight_default": 0.4
  },
  "timeline": [
