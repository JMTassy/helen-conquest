  "logging": {
    "metrics": [
      "pass_rate_real",
      "pass_rate_twin",
      "mirror_oracle_green",
      "mirror_oracle_yellow",
      "mirror_oracle_red",
      "retry_tax",
      "identity_drift_score",
      "smoothness_score",
      "credits_per_accepted_keyframe",
      "credits_per_final_minute"
    ],
    "write_manifest": true
  },
  "telegram": {
    "post_full_clip": true,
    "post_teaser_30s": true,
    "post_vertical_cut": true,
    "post_poster_grid": true,
    "caption_template": "HELEN test run {project.title} | REAL pass={pass_rate_real:.2f} | TWIN pass={pass_rate_twin:.2f} | Mirror {mirror_oracle_green}/{mirror_oracle_yellow}/{mirror_oracle_red} | retry_tax={retry_tax:.2f}"
