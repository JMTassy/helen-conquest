{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helen-os.canonical/schemas/task_list_v1.schema.json",
  "title": "TaskList v1",
  "description": "Planning layer output from HELEN. Tasks proposed for execution with priorities and resource requirements.",
  "type": "object",
  "required": [
    "task_list_id",
    "bundle_ref",
    "tasks",
    "total_tasks",
    "pending_count"
  ],
  "properties": {
    "task_list_id": {
      "type": "string",
      "pattern": "^TL-[a-f0-9]{8}$",
      "description": "Unique identifier for this task list"
    },
    "bundle_ref": {
      "type": "string",
      "pattern": "^EB-[a-f0-9]{8}$",
      "description": "References the EvidenceBundle being planned against"
    },
    "tasks": {
      "type": "array",
      "description": "Array of proposed tasks",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "priority",
          "domain",
          "complexity"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^T-[a-f0-9]{8}$"
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "1=high, 5=low"
          },
          "domain": {
            "type": "string",
            "description": "Task domain (skill area)"
          },
          "complexity": {
            "type": "number",
            "minimum": 0.1,
            "maximum": 1.0,
            "description": "Resource cost multiplier"
          },
          "estimated_agents": {
            "type": "integer",
            "minimum": 1,
            "description": "Suggested coalition size"
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Prerequisite task IDs"
          },
          "estimated_cost": {
            "type": "number",
            "minimum": 0,
            "description": "Estimated resource units needed"
          }
        }
      }
    },
    "total_tasks": {
      "type": "integer",
      "minimum": 0,
      "description": "Count of all tasks in this list"
    },
    "pending_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Tasks still to be executed"
    },
    "estimated_total_cost": {
      "type": "number",
      "minimum": 0,
      "description": "Sum of all estimated costs"
    }
  },
  "additionalProperties": false
}
