{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "helen://schemas/MISSION_V1",
  "title": "MISSION_V1",
  "description": "Mission: a structured set of steps to execute a proposal. Non-sovereign proposal layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "schema",
    "mission_id",
    "proposal_id",
    "kind",
    "objective",
    "constraints",
    "inputs",
    "steps",
    "status",
    "canonicalization"
  ],
  "properties": {
    "schema_name": {
      "const": "MISSION_V1"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "schema": {
      "type": "string",
      "const": "MISSION_V1"
    },
    "canonicalization": {
      "type": "string",
      "const": "JCS_SHA256_V1"
    },
    "mission_id": {
      "type": "string",
      "minLength": 1,
      "description": "Globally unique mission identifier"
    },
    "proposal_id": {
      "type": "string",
      "minLength": 1,
      "description": "Parent PROPOSAL_V1 that initiated this mission"
    },
    "kind": {
      "type": "string",
      "enum": [
        "RESEARCH",
        "BUILD",
        "AUDIT",
        "SIMULATION",
        "EVALUATION"
      ],
      "description": "Mission classification"
    },
    "objective": {
      "type": "string",
      "minLength": 1,
      "description": "What this mission aims to accomplish"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Rules or limitations for this mission"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ref",
          "kind"
        ],
        "properties": {
          "ref": {
            "type": "string",
            "minLength": 1,
            "description": "Reference to input artifact or resource"
          },
          "kind": {
            "type": "string",
            "enum": [
              "FILE",
              "CLAIM",
              "WORLD",
              "LEDGER",
              "PROMPT",
              "CONFIG"
            ],
            "description": "Type of input"
          },
          "hash": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[a-f0-9]{64}$",
            "description": "Optional SHA-256 hash of input for integrity"
          }
        }
      },
      "description": "Input artifacts required for this mission"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "action",
          "expected_receipt_type"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1,
            "description": "Step identifier within mission"
          },
          "action": {
            "type": "string",
            "minLength": 1,
            "description": "What to execute in this step"
          },
          "expected_receipt_type": {
            "type": "string",
            "enum": [
              "EXECUTION_RECEIPT_V1",
              "EVIDENCE_BUNDLE_V1",
              "ISSUE_LIST_V1"
            ],
            "description": "Expected output artifact type from this step"
          }
        }
      },
      "description": "Ordered steps to execute"
    },
    "status": {
      "type": "string",
      "enum": [
        "PLANNED",
        "ACTIVE",
        "BLOCKED",
        "COMPLETE"
      ],
      "description": "Current mission status"
    }
  }
}
