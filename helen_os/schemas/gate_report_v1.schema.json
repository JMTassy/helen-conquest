{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helen-os.canonical/schemas/gate_report_v1.schema.json",
  "title": "GateReport v1",
  "description": "Gate evaluation results. Records which gates passed and failed for an EvidenceBundle.",
  "type": "object",
  "required": [
    "gate_report_id",
    "bundle_ref",
    "gates",
    "overall_pass",
    "verdict_hash_hex"
  ],
  "properties": {
    "gate_report_id": {
      "type": "string",
      "pattern": "^GR-[a-f0-9]{8}$",
      "description": "Unique identifier for this gate report"
    },
    "bundle_ref": {
      "type": "string",
      "pattern": "^EB-[a-f0-9]{8}$",
      "description": "References the EvidenceBundle being gated"
    },
    "gates": {
      "type": "array",
      "description": "Array of gate evaluation results",
      "items": {
        "type": "object",
        "required": [
          "gate_id",
          "status"
        ],
        "properties": {
          "gate_id": {
            "type": "string",
            "enum": [
              "SCHEMA_VALID",
              "RECEIPT_VERIFY",
              "HASH_CHAIN_VALID",
              "MAYOR_CHECK",
              "AUTHORITY_SCAN",
              "KERNEL_ISOLATION"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["PASS", "FAIL", "DEFER"]
          },
          "message": {
            "type": "string",
            "description": "Explanation of result"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "When gate was evaluated"
          }
        }
      }
    },
    "overall_pass": {
      "type": "boolean",
      "description": "True if all gates PASS"
    },
    "gate_count_pass": {
      "type": "integer",
      "minimum": 0
    },
    "gate_count_fail": {
      "type": "integer",
      "minimum": 0
    },
    "verdict_hash_hex": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 of this gate evaluation (for receipt binding)"
    }
  },
  "additionalProperties": false
}
