{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "closure_receipt_v1.json",
  "title": "CLOSURE_RECEIPT_V1",
  "description": "Binds a seam closure claim to cryptographic evidence. Each claim must name an artifact with a verifiable SHA-256. Proposer and attestor are disjoint (Rule 3: no self-validation). A receipt with verdict CLOSED must have every claim verdict == PASS and observed_sha256 == expected_sha256.",
  "type": "object",
  "required": [
    "schema_name",
    "schema_version",
    "seam_id",
    "seam_title",
    "closure_version",
    "proposer",
    "attestor",
    "claims",
    "verdict",
    "closed_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_name": { "const": "CLOSURE_RECEIPT_V1" },
    "schema_version": { "const": "1.0.0" },
    "seam_id": {
      "type": "string",
      "pattern": "^SEAM-[0-9]{3}$",
      "description": "Stable seam identifier, e.g. SEAM-001."
    },
    "seam_title": { "type": "string", "minLength": 1 },
    "closure_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonic per-seam. V1, V2, V3 of Schema Authority were ghost closures; V4 is the first receipt-backed attempt."
    },
    "proposer": {
      "type": "object",
      "required": ["role", "identity"],
      "additionalProperties": false,
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "identity": { "type": "string", "minLength": 1 }
      }
    },
    "attestor": {
      "type": "object",
      "required": ["role", "identity"],
      "additionalProperties": false,
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "identity": { "type": "string", "minLength": 1 }
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim_id", "statement", "expected_artifact", "expected_sha256", "verdict"],
        "additionalProperties": false,
        "properties": {
          "claim_id": { "type": "string", "pattern": "^C[0-9]+$" },
          "statement": { "type": "string", "minLength": 1 },
          "expected_artifact": {
            "type": "string",
            "description": "Repository-relative path to a file OR a directory sentinel (trailing slash) whose existence is the claim."
          },
          "expected_sha256": {
            "type": "string",
            "pattern": "^(?:[a-f0-9]{64}|DIRECTORY_EMPTY|DIRECTORY_ABSENT)$",
            "description": "SHA-256 hex of the file bytes, OR a sentinel for directory-absence claims."
          },
          "verdict": { "enum": ["PASS", "FAIL", "MISSING"] },
          "observed_sha256": {
            "type": "string",
            "pattern": "^(?:[a-f0-9]{64}|DIRECTORY_EMPTY|DIRECTORY_ABSENT|DIRECTORY_NONEMPTY|FILE_ABSENT)$"
          },
          "note": { "type": "string" }
        }
      }
    },
    "verdict": { "enum": ["CLOSED", "BLOCKED", "RETRACTED"] },
    "retracts": {
      "type": "string",
      "description": "If this receipt retracts a prior one, the path to the retracted receipt."
    },
    "closed_at": { "type": "string", "format": "date-time" },
    "ledger_commit": { "type": "string" },
    "note": { "type": "string" }
  }
}
