{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conquest.local/schemas/town_routing_policy.schema.json",
  "title": "TOWN_ROUTING_POLICY_V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "thresholds",
    "hard_invariants"
  ],
  "properties": {
    "schema_version": {
      "const": "TOWN_ROUTING_POLICY_V1"
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ADVANCE", "HOLD", "RETURN"],
      "properties": {
        "ADVANCE": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "ℒ-score threshold for ADVANCE_TO_REVIEW routing"
        },
        "HOLD": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min", "max"],
          "properties": {
            "min": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "max": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            }
          },
          "description": "ℒ-score range for HOLD_FOR_REWORK routing"
        },
        "RETURN": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "ℒ-score threshold for RETURN_TO_RESEARCH routing"
        }
      }
    },
    "hard_invariants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "Non-negotiable laws (e.g., 'no receipt = no claim', 'Q_pol >= 0.7 mandatory')"
    },
    "quarantine_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["trigger", "action"],
        "properties": {
          "trigger": {
            "type": "string",
            "description": "Condition that triggers quarantine (e.g., 'tier == III', 'author_mode == WILD')"
          },
          "action": {
            "type": "string",
            "enum": ["QUARANTINE", "RETURN", "HOLD"],
            "description": "Routing action when trigger is satisfied"
          }
        }
      },
      "description": "Rules for automatic routing decisions"
    }
  }
}
