{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TEMPLE_EXPLORATION_V1",
  "description": "Non-sovereign generative exploration artifact. Structured HER/HAL dialog, tension map, candidate sketches. Authority=NONE. No state mutation. All governance through bridge→mayor.",
  "type": "object",
  "properties": {
    "schema_name": {
      "const": "TEMPLE_EXPLORATION_V1"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "session_id": {
      "type": "string",
      "description": "Unique exploration session identifier"
    },
    "theme": {
      "type": "string",
      "description": "Exploration theme or research question"
    },
    "her_threads": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "thread_id": { "type": "string" },
          "persona": { "type": "string", "enum": ["HER", "HAL", "PARTICIPANT"] },
          "content": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "evidence": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["thread_id", "persona", "content"],
        "additionalProperties": false
      },
      "description": "Dialog threads between HER (planner) and HAL (auditor)"
    },
    "hal_frictions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "friction_id": { "type": "string" },
          "category": { "type": "string", "enum": ["SCHEMA_QUESTION", "EVIDENCE_GAP", "INCONSISTENCY", "RISK_NOTED"] },
          "description": { "type": "string" },
          "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
          "resolution_draft": { "type": "string" }
        },
        "required": ["friction_id", "category", "description"],
        "additionalProperties": false
      },
      "description": "HAL's structural critiques and inconsistencies found during exploration"
    },
    "tension_map": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tension_id": { "type": "string" },
          "pole_a": { "type": "string" },
          "pole_b": { "type": "string" },
          "current_position": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "narrative": { "type": "string" }
        },
        "required": ["tension_id", "pole_a", "pole_b"],
        "additionalProperties": false
      },
      "description": "Identified tensions and their current balance points"
    },
    "center_sketches": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sketch_id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["PROPOSAL", "COUNTEREXAMPLE", "ANALOGY", "BOUNDARY_CASE"] },
          "description": { "type": "string" },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "risk_assessment": { "type": "string" }
        },
        "required": ["sketch_id", "name", "type", "description"],
        "additionalProperties": false
      },
      "description": "Core ideas and structural sketches from exploration"
    },
    "export_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "candidate_id": { "type": "string" },
          "artifact_type": { "type": "string", "enum": ["SKILL_DISCOVERY", "MEMORY_ENTRY", "POLICY_PROPOSAL", "DEFINITION"] },
          "content": { "type": "object" },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "bridge_required": { "type": "boolean" },
          "notes": { "type": "string" }
        },
        "required": ["candidate_id", "artifact_type", "content", "bridge_required"],
        "additionalProperties": false
      },
      "description": "Candidates for transmission to Mayor through temple_bridge"
    },
    "timestamp_start": {
      "type": "string",
      "format": "date-time",
      "description": "When exploration began"
    },
    "timestamp_end": {
      "type": "string",
      "format": "date-time",
      "description": "When exploration concluded"
    },
    "authority": {
      "const": "NONE",
      "description": "TEMPLE exploration has zero authority over governance. All decisions require Mayor admission."
    }
  },
  "required": [
    "schema_name",
    "schema_version",
    "session_id",
    "theme",
    "her_threads",
    "hal_frictions",
    "timestamp_start",
    "authority"
  ],
  "additionalProperties": false,
  "forbidden_keys": [
    "verdict",
    "state_mutation",
    "ship",
    "no_ship",
    "decision",
    "receipt_claimed",
    "authorized_by"
  ]
}
