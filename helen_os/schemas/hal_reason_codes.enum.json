        "COUPLING_INVALID_RECEIPT": "CouplingGate: support receipt invalid",
        "COUPLING_FORECAST_REJECTED": "CouplingGate: forecast rejected by OracleTown"
      }
    },
    "byzantine": {
      "description": "Byzantine detection and recovery",
      "codes": {
        "BYZANTINE_DETECTION_OK": "No Byzantine behavior detected",
