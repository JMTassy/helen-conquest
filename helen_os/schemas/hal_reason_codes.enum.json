{
  "title": "HAL Reason Code Enumeration",
  "description": "Stable, deterministic reason codes for MAYOR verdicts. All codes MUST be lexicographically sorted in output.",
  "meta": {
    "version": "1.0.0",
    "date": "2026-02-22",
    "policy": "Codes are frozen once in production. New codes require amendment process."
  },
  "categories": {
    "schema_validation": {
      "description": "Payload structure validation",
      "codes": {
        "INVALID_HAL_SCHEMA": "HAL object does not match HAL_VERDICT_V1",
        "INVALID_PAYLOAD_SCHEMA": "Payload structure invalid",
        "MISSING_REQUIRED_FIELD": "Required field missing",
        "INVALID_ENUM_VALUE": "Enum field has invalid value",
        "REASONS_NOT_SORTED": "reasons_codes not in lexicographic order",
        "FIXES_NOT_SORTED": "required_fixes not in lexicographic order",
        "REASON_CODE_INVALID_FORMAT": "Reason code does not match ^[A-Z0-9_]{3,64}$",
        "VERDICT_MUTATION_RULE": "mutations present but verdict is PASS (must be WARN/BLOCK)"
      }
    },
    "determinism": {
      "description": "Determinism and reproducibility checks",
      "codes": {
        "NONDETERMINISM_TIMESTAMP": "Wall-clock timestamp found in payload (belongs in meta)",
        "NONDETERMINISM_RANDOM_ID": "Non-deterministic ID generation detected",
        "NONDETERMINISM_UNSEEDED_RNG": "Unseeded randomness in payload",
        "NONDETERMINISM_LOCALE_DEPENDENT": "Locale-dependent formatting detected"
      }
    },
    "hash_integrity": {
      "description": "Hash chain verification",
      "codes": {
        "PAYLOAD_HASH_MISMATCH": "Computed SHA256(payload) != payload_hash",
        "CUM_HASH_MISMATCH": "Computed cum_hash != declared cum_hash",
        "HASH_CHAIN_BROKEN": "cum_hash chain is not monotonically valid",
        "IDENTITY_HASH_MISMATCH": "identity_hash mismatch (kernel/policy/ledger hash changed)"
      }
    },
    "governance_gates": {
      "description": "K-τ, K-ρ, CouplingGate results",
      "codes": {
